{
  "manifest_version": 2,
  "name": "TrumpOrNot Curator",
  "version": "0.1.0",
  "description": "Capture X posts and save them to your TrumpOrNot database.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "https://x.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "browser_action": {
    "default_title": "TrumpOrNot Curator",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*"],
      "js": ["shared.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
