{
  "manifest_version": 2,
  "name": "TrumpOrNot Curator",
  "version": "0.1.0",
  "description": "Capture X and Truth Social posts and save them to your TrumpOrNot database.",
  "permissions": [
    "activeTab",
    "storage",
    "https://trumpornot.tlam.art/*",
    "https://x.com/*",
    "https://truthsocial.com/*",
    "https://www.truthsocial.com/*"
  ],
  "optional_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "browser_action": {
    "default_title": "TrumpOrNot Curator",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://truthsocial.com/*", "https://www.truthsocial.com/*"],
      "js": ["shared.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
